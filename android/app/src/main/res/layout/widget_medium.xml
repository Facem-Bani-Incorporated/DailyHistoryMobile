<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <View
            android:layout_width="3dp"
            android:layout_height="32dp"
            android:background="#FFD700"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2024"
                android:textColor="#FFD700"
                android:textSize="12sp"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DAILY HISTORY"
                android:textColor="#40FFFFFF"
                android:textSize="8sp"
                android:letterSpacing="0.2"/>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_impact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ 0%"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:background="@drawable/impact_badge_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daily History"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif-black"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/widget_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next in 0h 0m"
        android:textColor="#60FFFFFF"
        android:textSize="10sp"/>

</LinearLayout>