{
  "expo": {
    "name": "DailyHistoryMobile",
    "slug": "dailyhistorymobile",
    "version": "1.0.0",
    "icon": "./assets/icon.svg",
    "orientation": "portrait",
    "scheme": "dailyhistorymobile",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.svg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rexinus.DailyHistoryMobile",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.rexinus.DailyHistoryMobile",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBbop9-i1QUSjUD6WUUFvFEvv7xQgYKqrw"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.svg",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2338557822432313~1610999137",
          "iosAppId": "ca-app-pub-2338557822432313~9366767475"
        }
      ],
      "@react-native-firebase/app",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "dailyhistory",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3353636b-95c7-4b0d-955a-e24541d5c5c4"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/3353636b-95c7-4b0d-955a-e24541d5c5c4"
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-2338557822432313~1610999137",
    "ios_app_id": "ca-app-pub-2338557822432313~9366767475"
  }
}
