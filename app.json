{
  "expo": {
    "name": "DailyHistoryMobile",
    "slug": "DailyHistoryMobile",
    "version": "1.0.0",
    "icon": "./assets/icon.svg",
    "orientation": "portrait",
    "scheme": "dailyhistorymobile",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.svg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rexinus.DailyHistoryMobile"
    },
    "android": {
      "package": "com.rexinus.DailyHistoryMobile",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBbop9-i1QUSjUD6WUUFvFEvv7xQgYKqrw"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.svg",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2338557822432313~1610999137"
        }
      ],
      "@react-native-firebase/app"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "40d2f71e-3f11-4574-b212-a7f3cd044377"
      }
    },
    "owner": "rexinus",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/40d2f71e-3f11-4574-b212-a7f3cd044377"
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-2338557822432313~1610999137"
  }
}
